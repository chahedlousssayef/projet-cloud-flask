# Copier vers .env et remplir. Ne pas commiter .env

FLASK_ENV=production
FLASK_PORT=5000

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<mot-de-passe>
POSTGRES_DB=flaskapp
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Azure Blob Storage (chaîne de connexion complète)
# Format: DefaultEndpointsProtocol=https;AccountName=XXX;AccountKey=XXX;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONNECTION_STRING=<connection-string>
AZURE_STORAGE_CONTAINER_NAME=flask-files
